# This is Git's per-user configuration file.
[user]
	name = Jack Lucky
	email = jack.lucky.iv@gmail.com
[alias]
	co = checkout
  cob = checkout -b
	br = branch
	ci = commit
	st = status
	unstage = reset HEAD --
	last = log -1 HEAD
	aa = add --all
	cim = commit -m
	ctags = !.git/hooks/ctags
	ignore = "!gi() { curl -L -s https://www.gitignore.io/api/$@ ;}; gi"
[init]
	templatedir = ~/.git_template
